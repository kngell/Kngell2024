
# This .htaccess file is used to redirect all requests to the public folder
# Disable directory listing for all folders
Options -Indexes

<IfModule mod_rewrite.c>
    # Enable rewrite engine
    RewriteEngine on

    # Base directory
    RewriteBase /

    ## Begin - Well-Known Directory Handling
    # Handle .well-known requests before redirecting to public
    # If the .well-known file exists in public, serve it directly
    RewriteCond %{REQUEST_URI} ^/\.well-known/
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ /public/$1 [L]
    
    # Return 404 for non-existent .well-known files (don't redirect to public)
    RewriteCond %{REQUEST_URI} ^/\.well-known/
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} !-f
    RewriteRule ^(.*)$ - [R=404,L]
    ## End - Well-Known Directory Handling

    # Redirect all other requests to the public folder
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ /public/$1 [L]

    # Optional: If you want to redirect without changing the URL in the browser
    # RewriteRule ^(.*)$ /public/$1 [L]

    # Optional: If you want to force the use of index.php
    # RewriteCond %{REQUEST_FILENAME} !-f
    # RewriteRule ^(.*)$ /public/index.php?url=$1 [QSA,L]
</IfModule>

